# FlowraAI Config Example
# -------------------------

# Security: JWT
FLOWRA_JWT_SECRET=paste_your_32_plus_char_random_secret_here
FLOWRA_JWT_ALGORITHM=HS256

# Security: Admin
FLOWRA_ADMIN_KEY=your_admin_secret_key_for_whitelists_and_appeals

# Infrastructure: Redis
USE_REDIS=false
REDIS_URL=redis://localhost:6379/0

# Logic: Block TTLs (seconds)
BLOCK_TTL_RATE_LIMIT=300
BLOCK_TTL_RISK=3600
